<?xml version="1.0"?>
<robot name="ackermann_car">

  <!-- ================= Materials ================= -->

  <material name="chassis_blue">
    <color rgba="0.05 0.25 0.85 1.0"/>
  </material>

  <material name="wheel_black">
    <color rgba="0.01 0.01 0.01 1.0"/>
  </material>

  <material name="steer_gray">
    <color rgba="0.45 0.45 0.45 1.0"/>
  </material>

  <!-- ================= Base / Chassis ================= -->

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <mass value="12.0"/>
      <inertia
        ixx="0.45"
        ixy="0.0"
        ixz="0.0"
        iyy="1.20"
        iyz="0.0"
        izz="1.50"/>
    </inertial>
  </link>

  <link name="chassis_link">
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <box size="1.60 0.80 0.30"/>
      </geometry>
      <material name="chassis_blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <box size="1.60 0.80 0.30"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <mass value="12.0"/>
      <inertia
        ixx="0.45"
        ixy="0.0"
        ixz="0.0"
        iyy="1.20"
        iyz="0.0"
        izz="1.50"/>
    </inertial>
  </link>

  <joint name="base_to_chassis_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chassis_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ================= Front Steering Links ================= -->

  <link name="front_left_steer_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.12 0.12"/>
      </geometry>
      <material name="steer_gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.12 0.12"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <link name="front_right_steer_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.12 0.12"/>
      </geometry>
      <material name="steer_gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.12 0.12"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <!-- Front steering joints rotate around Z axis -->
  <joint name="front_left_steer_joint" type="revolute">
    <parent link="chassis_link"/>
    <child link="front_left_steer_link"/>
    <origin xyz="0.55 0.45 0.12" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.6" upper="0.6" effort="20.0" velocity="2.0"/>
  </joint>

  <joint name="front_right_steer_joint" type="revolute">
    <parent link="chassis_link"/>
    <child link="front_right_steer_link"/>
    <origin xyz="0.55 -0.45 0.12" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.6" upper="0.6" effort="20.0" velocity="2.0"/>
  </joint>

  <!-- ================= Wheels ================= -->

  <link name="front_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.16" length="0.10"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.16" length="0.10"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.006"/>
    </inertial>
  </link>

  <link name="front_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.16" length="0.10"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.16" length="0.10"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.006"/>
    </inertial>
  </link>

  <link name="rear_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.16" length="0.10"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.16" length="0.10"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.006"/>
    </inertial>
  </link>

  <link name="rear_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.16" length="0.10"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.16" length="0.10"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.006"/>
    </inertial>
  </link>

  <!-- Front wheel spin joints -->
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="front_left_steer_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="front_right_steer_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Rear wheel spin joints -->
  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="chassis_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.55 0.45 0.12" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="chassis_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.55 -0.45 0.12" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================= Sensor Mounts ================= -->

  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
      <material name="steer_gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="chassis_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.25 0 0.48" rpy="0 0 0"/>
  </joint>

</robot>
