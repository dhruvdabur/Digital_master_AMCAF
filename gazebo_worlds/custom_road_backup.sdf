    <!-- Smooth visual road overlay: hides the faceted/cut borders from the original box segments. -->
    <model name="smooth_road_overlay">
      <static>true</static>
      <link name="road_visuals">
        <visual name="continuous_yellow_border">
          <pose>0 0 0.038 0 0 0</pose>
          <geometry>
            <mesh>
              <uri>models/smooth_road/meshes/yellow_border.obj</uri>
            </mesh>
          </geometry>
          <material>
            <ambient>1.0 0.78 0.0 1.0</ambient>
            <diffuse>1.0 0.78 0.0 1.0</diffuse>
            <specular>0.08 0.08 0.06 1.0</specular>
          </material>
        </visual>
        <visual name="continuous_asphalt">
          <pose>0 0 0.044 0 0 0</pose>
          <geometry>
            <mesh>
              <uri>models/smooth_road/meshes/asphalt.obj</uri>
            </mesh>
          </geometry>
          <material>
            <ambient>0.13 0.13 0.13 1.0</ambient>
            <diffuse>0.13 0.13 0.13 1.0</diffuse>
            <specular>0.035 0.035 0.035 1.0</specular>
          </material>
        </visual>
        <visual name="center_lane_line">
          <pose>0 0 0.052 0 0 0</pose>
          <geometry>
            <mesh>
              <uri>models/smooth_road/meshes/center_line.obj</uri>
            </mesh>
          </geometry>
          <material>
            <ambient>0.95 0.95 0.9 1.0</ambient>
            <diffuse>0.95 0.95 0.9 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Lightweight dynamic traffic: visual actors loop on the two lanes. -->

    <actor name="traffic_car_blue">
      <pose>0 0 0 0 0 0</pose>
      <link name="body_link">
        <visual name="body">
          <pose>0 0 0.12 0 0 0</pose>
          <geometry>
            <box>
              <size>2.4 1.05 0.35</size>
            </box>
          </geometry>
          <material>
            <ambient>0.05 0.20 0.95 1</ambient>
            <diffuse>0.05 0.20 0.95 1</diffuse>
            <specular>0.45 0.45 0.45 1</specular>
          </material>
        </visual>
        <visual name="cabin">
          <pose>0.18 0 0.42 0 0 0</pose>
          <geometry>
            <box>
              <size>1.05 0.86 0.34</size>
            </box>
          </geometry>
          <material>
            <ambient>0.06 0.09 0.12 1</ambient>
            <diffuse>0.08 0.12 0.16 1</diffuse>
            <specular>0.4 0.4 0.45 1</specular>
          </material>
        </visual>
        <visual name="front_marker">
          <pose>1.23 0 0.22 0 0 0</pose>
          <geometry>
            <box>
              <size>0.05 0.82 0.12</size>
            </box>
          </geometry>
          <material>
            <ambient>1 0.95 0.72 1</ambient>
            <diffuse>1 0.95 0.72 1</diffuse>
          </material>
        </visual>
        <visual name="rear_marker">
          <pose>-1.23 0 0.21 0 0 0</pose>
          <geometry>
            <box>
              <size>0.05 0.82 0.12</size>
            </box>
          </geometry>
          <material>
            <ambient>0.8 0.04 0.03 1</ambient>
            <diffuse>0.8 0.04 0.03 1</diffuse>
          </material>
        </visual>
        <visual name="left_wheels">
          <pose>0 0.58 0.02 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.22</radius>
              <length>2.0</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.015 0.015 0.015 1</ambient>
            <diffuse>0.015 0.015 0.015 1</diffuse>
          </material>
        </visual>
        <visual name="right_wheels">
          <pose>0 -0.58 0.02 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.22</radius>
              <length>2.0</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.015 0.015 0.015 1</ambient>
            <diffuse>0.015 0.015 0.015 1</diffuse>
          </material>
        </visual>
      </link>
      <script>
        <loop>true</loop>
        <auto_start>true</auto_start>
        <trajectory id="0" type="traffic_loop" tension="0.8">
          <waypoint>
            <time>0.000</time>
            <pose>31.450 0.000 0.420 0 0 1.571</pose>
          </waypoint>
          <waypoint>
            <time>0.885</time>
            <pose>30.813 4.316 0.420 0 0 1.861</pose>
          </waypoint>
          <waypoint>
            <time>1.771</time>
            <pose>28.948 8.419 0.420 0 0 2.127</pose>
          </waypoint>
          <waypoint>
