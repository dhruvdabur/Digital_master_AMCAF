<?xml version="1.0" ?>
<sdf version='1.7'>
  <world name='custom_road_world'>
    <scene>
      <ambient>1.0 1.0 1.0</ambient>
      <background>0.8 0.8 0.8</background>
      <sky></sky>
    </scene>
    <plugin
      filename="ignition-gazebo-physics-system"
      name="ignition::gazebo::systems::Physics">
    </plugin>
    <plugin
      filename="ignition-gazebo-sensors-system"
      name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin
      filename="ignition-gazebo-user-commands-system"
      name="ignition::gazebo::systems::UserCommands">
    </plugin>
    <plugin
      filename="ignition-gazebo-scene-broadcaster-system"
      name="ignition::gazebo::systems::SceneBroadcaster">
    </plugin>

    <!-- Local ground plane and sun keep the world grounded even without Fuel access. -->
    <model name="ground_plane">
      <static>true</static>
      <pose>25 -32 -0.005 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>180 180</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>180 180</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.54 0.56 0.54 1</ambient>
            <diffuse>0.54 0.56 0.54 1</diffuse>
            <specular>0.04 0.04 0.04 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 20 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.3 -0.8</direction>
    </light>

    <!-- Custom Elliptical Road Model -->
        <model name="elliptical_road">
      <static>true</static>

    <link name="seg_0">
      <pose>6.089 1.763 0.01 0 0 0.006</pose>
      
      <!-- Yellow Border Base -->
      <visual name="yellow_base_0">
        <pose>0 0 0.001 0 0 0</pose>
        <geometry>
          <box>
            <size>2.0 6.4 0.02</size>
          </box>
        </geometry>
        <material>
