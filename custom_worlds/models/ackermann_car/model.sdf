<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="ackermann_car">

    <pose>0 0 0.25 0 0 0</pose>

    <!-- Chassis -->
    <link name="chassis_link">
      <pose>0 0 0.25 0 0 0</pose>

      <inertial>
        <mass>12.0</mass>
        <inertia>
          <ixx>0.45</ixx>
          <iyy>1.20</iyy>
          <izz>1.50</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="chassis_collision">
        <geometry>
          <box>
            <size>1.6 0.8 0.30</size>
          </box>
        </geometry>
      </collision>

      <visual name="chassis_visual">
        <geometry>
          <box>
            <size>1.6 0.8 0.30</size>
          </box>
        </geometry>
        <material>
          <ambient>0.05 0.25 0.85 1</ambient>
          <diffuse>0.05 0.25 0.85 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- Front steering knuckles -->
    <link name="front_left_steer_link">
      <pose>0.55 0.45 0.12 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.002</ixx>
          <iyy>0.002</iyy>
          <izz>0.002</izz>
        </inertia>
      </inertial>
    </link>

    <link name="front_right_steer_link">
      <pose>0.55 -0.45 0.12 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.002</ixx>
          <iyy>0.002</iyy>
          <izz>0.002</izz>
        </inertia>
      </inertial>
    </link>

    <!-- Front left wheel -->
    <link name="front_left_wheel">
      <pose>0.55 0.45 0.12 1.5708 0 0</pose>

      <inertial>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.006</ixx>
          <iyy>0.006</iyy>
          <izz>0.006</izz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.16</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.16</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.01 0.01 0.01 1</ambient>
          <diffuse>0.01 0.01 0.01 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- Front right wheel -->
    <link name="front_right_wheel">
      <pose>0.55 -0.45 0.12 1.5708 0 0</pose>

      <inertial>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.006</ixx>
          <iyy>0.006</iyy>
          <izz>0.006</izz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.16</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.16</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.01 0.01 0.01 1</ambient>
          <diffuse>0.01 0.01 0.01 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- Rear left wheel -->
    <link name="rear_left_wheel">
      <pose>-0.55 0.45 0.12 1.5708 0 0</pose>

      <inertial>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.006</ixx>
          <iyy>0.006</iyy>
          <izz>0.006</izz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.16</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.16</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.01 0.01 0.01 1</ambient>
          <diffuse>0.01 0.01 0.01 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- Rear right wheel -->
    <link name="rear_right_wheel">
      <pose>-0.55 -0.45 0.12 1.5708 0 0</pose>

      <inertial>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.006</ixx>
          <iyy>0.006</iyy>
          <izz>0.006</izz>
        </inertia>
      </inertial>

      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.16</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.16</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.01 0.01 0.01 1</ambient>
          <diffuse>0.01 0.01 0.01 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- Steering joints -->
    <joint name="front_left_steer_joint" type="revolute">
      <parent>chassis_link</parent>
      <child>front_left_steer_link</child>
      <pose>0.55 0.45 0.12 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.6</lower>
          <upper>0.6</upper>
          <effort>20</effort>
          <velocity>2</velocity>
        </limit>
      </axis>
    </joint>

    <joint name="front_right_steer_joint" type="revolute">
      <parent>chassis_link</parent>
      <child>front_right_steer_link</child>
      <pose>0.55 -0.45 0.12 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.6</lower>
          <upper>0.6</upper>
          <effort>20</effort>
          <velocity>2</velocity>
        </limit>
      </axis>
    </joint>

    <!-- Wheel spin joints -->
    <joint name="front_left_wheel_joint" type="revolute">
      <parent>front_left_steer_link</parent>
      <child>front_left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <joint name="front_right_wheel_joint" type="revolute">
      <parent>front_right_steer_link</parent>
      <child>front_right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>chassis_link</parent>
      <child>rear_left_wheel</child>
      <pose>-0.55 0.45 0.12 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>chassis_link</parent>
      <child>rear_right_wheel</child>
      <pose>-0.55 -0.45 0.12 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <!-- Ackermann controller -->
    <plugin
      filename="ignition-gazebo-ackermann-steering-system"
      name="ignition::gazebo::systems::AckermannSteering">

      <!-- Rear driving wheels -->
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>

      <!-- Front steering joints -->
      <left_steering_joint>front_left_steer_joint</left_steering_joint>
      <right_steering_joint>front_right_steer_joint</right_steering_joint>

      <wheel_separation>0.90</wheel_separation>
      <kingpin_width>0.90</kingpin_width>
      <wheel_base>1.10</wheel_base>
      <wheel_radius>0.16</wheel_radius>
      <steering_limit>0.6</steering_limit>

      <min_velocity>-2.0</min_velocity>
      <max_velocity>2.0</max_velocity>
      <min_acceleration>-2.5</min_acceleration>
      <max_acceleration>2.5</max_acceleration>

      <topic>/model/ackermann_car/cmd_vel</topic>
      <odom_topic>/model/ackermann_car/odometry</odom_topic>
      <tf_topic>/model/ackermann_car/tf</tf_topic>
      <odom_publish_frequency>50</odom_publish_frequency>

      <frame_id>ackermann_car/odom</frame_id>
      <child_frame_id>ackermann_car/chassis_link</child_frame_id>
    </plugin>

  </model>
</sdf>
